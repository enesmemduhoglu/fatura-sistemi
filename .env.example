# Örnek ortam dosyası: kopyalayıp ".env" olarak kaydedin ve değerleri doldurun.
# .env git'e girmez; bu şablon depoda kalır.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=isbasi
DB_USER=postgres
DB_PASSWORD=parolanizi-buraya-yazin

# Sıfırdan kurulumda oluşturulacak ilk kullanıcının parolası.
# Boş bırakılırsa geliştirme varsayılanı kullanılır; mevcut veritabanını etkilemez.
SEED_USER_PASSWORD=ilk-kullanici-parolasi
