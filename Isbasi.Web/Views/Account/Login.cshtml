@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giriş Yap | Logo İşbaşı</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">
    <style>
        body {
            font-family: 'Poppins', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #e8112d 0%, #a30b1f 100%);
        }
        .login-card {
            background: #fff;
            border-radius: 10px;
            box-shadow: 0 10px 40px rgba(0,0,0,.25);
            width: 100%;
            max-width: 420px;
            padding: 40px 36px;
        }
        .brand { text-align: center; margin-bottom: 28px; }
        .brand .logo-text { font-size: 15px; font-weight: 300; color: #e8112d; }
        .brand .brand-name { font-size: 30px; font-weight: 700; font-style: italic; color: #e8112d; }
        .btn-login { background: #e8112d; color: #fff; font-weight: 600; padding: 10px; }
        .btn-login:hover { background: #c60e26; color: #fff; }
        .form-control:focus { border-color: #e8112d; box-shadow: 0 0 0 .15rem rgba(232,17,45,.15); }
        .hint { font-size: 12px; color: #a5a7b8; text-align: center; margin-top: 18px; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="brand">
            <span class="logo-text">logo</span> <span class="brand-name">İŞBAŞI</span> <i class="fas fa-anchor" style="color:#e8112d"></i>
            <div class="text-muted mt-1" style="font-size:13px">Ön muhasebe programına giriş yapın</div>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger py-2" style="font-size:13px"><i class="fas fa-exclamation-circle me-1"></i>@ViewBag.Error</div>
        }

        <form method="post" action="/account/login">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
            <div class="mb-3">
                <label class="form-label" style="font-size:13px">E-Posta</label>
                <input type="email" name="email" class="form-control" placeholder="ornek@eposta.com" required autofocus>
            </div>
            <div class="mb-4">
                <label class="form-label" style="font-size:13px">Parola</label>
                <input type="password" name="password" class="form-control" placeholder="••••••••" required>
            </div>
            <button type="submit" class="btn btn-login w-100"><i class="fas fa-sign-in-alt me-2"></i>Giriş Yap</button>
        </form>

        <div class="hint">© @DateTime.Today.Year Logo İşbaşı Klonu</div>
    </div>
</body>
</html>
