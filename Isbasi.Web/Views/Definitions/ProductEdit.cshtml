@model Product
@{
    ViewData["Title"] = Model.Id == 0 ? "Yeni Ürün" : "Ürün Düzenle";
}

<div class="page-header">
    <h1 class="page-title"><span class="breadcrumb-part">Ürünler &gt;</span> @ViewData["Title"]</h1>
</div>

<div class="portlet">
    <form method="post" action="/definitions/product/edit">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label" asp-for="Code"></label>
                <input class="form-control" asp-for="Code" />
            </div>
            <div class="col-md-8">
                <label class="form-label" asp-for="Name"></label>
                <input class="form-control" asp-for="Name" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label class="form-label" asp-for="Unit"></label>
                <select class="form-select" asp-for="Unit">
                    <option>Adet</option>
                    <option>Kg</option>
                    <option>Gr</option>
                    <option>Lt</option>
                    <option>Mt</option>
                    <option>M2</option>
                    <option>Koli</option>
                    <option>Paket</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label" asp-for="SalePrice"></label>
                <input class="form-control" asp-for="SalePrice" />
            </div>
            <div class="col-md-4">
                <label class="form-label" asp-for="PurchasePrice"></label>
                <input class="form-control" asp-for="PurchasePrice" />
            </div>
            <div class="col-md-4">
                <label class="form-label" asp-for="VatRate"></label>
                <select class="form-select" asp-for="VatRate">
                    <option value="0">%0</option>
                    <option value="1">%1</option>
                    <option value="10">%10</option>
                    <option value="20">%20</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label" asp-for="StockAmount"></label>
                <input class="form-control" asp-for="StockAmount" />
            </div>
        </div>

        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-save"><i class="fas fa-save me-1"></i> Kaydet</button>
            <a href="/definitions/product" class="btn btn-cancel"><i class="fas fa-times me-1"></i> Vazgeç</a>
        </div>
    </form>
</div>
