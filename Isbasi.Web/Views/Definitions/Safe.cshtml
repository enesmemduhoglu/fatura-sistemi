@model List<Safe>
@{
    ViewData["Title"] = "Kasalar";
}

<div class="page-header">
    <h1 class="page-title">Kasalar</h1>
    <a href="/definitions/safe/edit" class="btn btn-isbasi"><i class="fas fa-plus me-1"></i> Yeni Kasa</a>
</div>

<div class="portlet">
    @if (Model.Count == 0)
    {
        <div class="empty-state">
            <i class="fas fa-cash-register"></i>
            <div class="title">Kayıtlı kasa bulunamadı</div>
            <div>"Yeni Kasa" butonu ile ilk kasanızı oluşturun.</div>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Kasa Adı</th>
                        <th>Döviz</th>
                        <th class="text-end">Bakiye</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var safe in Model)
                    {
                        <tr>
                            <td class="fw-medium"><i class="fas fa-cash-register me-2 text-muted"></i>@safe.Name</td>
                            <td>@safe.Currency</td>
                            <td class="text-end fw-medium">@safe.OpeningBalance.ToString("N2") ₺</td>
                            <td class="text-end">
                                <a href="/definitions/safe/edit?id=@safe.Id" class="btn btn-sm btn-outline-primary" title="Düzenle"><i class="fas fa-pen"></i></a>
                                <form method="post" action="/definitions/safe/delete/@safe.Id" class="d-inline"
                                      onsubmit="return confirm('@safe.Name silinsin mi?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Sil"><i class="fas fa-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="text-muted small">Toplam kasa bakiyesi: <strong>@Model.Sum(s => s.OpeningBalance).ToString("N2") ₺</strong></div>
    }
</div>
