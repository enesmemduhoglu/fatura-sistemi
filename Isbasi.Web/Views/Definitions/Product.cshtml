@model List<Product>
@{
    ViewData["Title"] = "Ürünler";
}

<div class="page-header">
    <h1 class="page-title">Ürünler</h1>
    <a href="/definitions/product/edit" class="btn btn-isbasi"><i class="fas fa-plus me-1"></i> Yeni Ürün</a>
</div>

<div class="portlet">
    <form method="get" class="row g-2 mb-3">
        <div class="col-md-5">
            <div class="input-group">
                <span class="input-group-text bg-white"><i class="fas fa-search"></i></span>
                <input type="text" name="q" value="@ViewBag.Query" class="form-control" placeholder="Ürün adı ya da kodu ile Ara...">
            </div>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-outline-secondary w-100">Ara</button>
        </div>
    </form>

    @if (Model.Count == 0)
    {
        <div class="empty-state">
            <i class="fas fa-barcode"></i>
            <div class="title">Kayıtlı ürün bulunamadı</div>
            <div>"Yeni Ürün" butonu ile ilk ürününüzü oluşturun.</div>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Ürün Kodu</th>
                        <th>Ürün Adı</th>
                        <th>Birimi</th>
                        <th class="text-end">Satış Fiyatı</th>
                        <th class="text-end">Alış Fiyatı</th>
                        <th class="text-end">KDV %</th>
                        <th class="text-end">Stok Miktarı</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in Model)
                    {
                        <tr>
                            <td>@product.Code</td>
                            <td class="fw-medium">@product.Name</td>
                            <td>@product.Unit</td>
                            <td class="text-end">@product.SalePrice.ToString("N2") ₺</td>
                            <td class="text-end">@product.PurchasePrice.ToString("N2") ₺</td>
                            <td class="text-end">%@product.VatRate.ToString("N0")</td>
                            <td class="text-end">@product.StockAmount.ToString("N0")</td>
                            <td class="text-end">
                                <a href="/definitions/product/edit?id=@product.Id" class="btn btn-sm btn-outline-primary" title="Düzenle"><i class="fas fa-pen"></i></a>
                                <form method="post" action="/definitions/product/delete/@product.Id" class="d-inline"
                                      onsubmit="return confirm('@product.Name silinsin mi?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Sil"><i class="fas fa-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
