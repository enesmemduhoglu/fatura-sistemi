@model List<Service>
@{
    ViewData["Title"] = "Hizmetler";
}

<div class="page-header">
    <h1 class="page-title">Hizmetler</h1>
    <a href="/definitions/service/edit" class="btn btn-isbasi"><i class="fas fa-plus me-1"></i> Yeni Hizmet</a>
</div>

<div class="portlet">
    <form method="get" class="row g-2 mb-3">
        <div class="col-md-5">
            <div class="input-group">
                <span class="input-group-text bg-white"><i class="fas fa-search"></i></span>
                <input type="text" name="q" value="@ViewBag.Query" class="form-control" placeholder="Hizmet adı ya da kodu ile Ara...">
            </div>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-outline-secondary w-100">Ara</button>
        </div>
    </form>

    @if (Model.Count == 0)
    {
        <div class="empty-state">
            <i class="fas fa-suitcase"></i>
            <div class="title">Kayıtlı hizmet bulunamadı</div>
            <div>"Yeni Hizmet" butonu ile ilk hizmetinizi oluşturun.</div>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Hizmet Kodu</th>
                        <th>Hizmet Adı</th>
                        <th>Birimi</th>
                        <th class="text-end">Birim Fiyat</th>
                        <th class="text-end">KDV %</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var service in Model)
                    {
                        <tr>
                            <td>@service.Code</td>
                            <td class="fw-medium">@service.Name</td>
                            <td>@service.Unit</td>
                            <td class="text-end">@service.Price.ToString("N2") ₺</td>
                            <td class="text-end">%@service.VatRate.ToString("N0")</td>
                            <td class="text-end">
                                <a href="/definitions/service/edit?id=@service.Id" class="btn btn-sm btn-outline-primary" title="Düzenle"><i class="fas fa-pen"></i></a>
                                <form method="post" action="/definitions/service/delete/@service.Id" class="d-inline"
                                      onsubmit="return confirm('@service.Name silinsin mi?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Sil"><i class="fas fa-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
