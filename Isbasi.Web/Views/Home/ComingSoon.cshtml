@{
    ViewData["Title"] = ViewBag.Title;
}

<div class="page-header">
    <h1 class="page-title">@ViewBag.Title</h1>
</div>

<div class="portlet">
    <div class="empty-state">
        <i class="fas fa-tools"></i>
        <div class="title">@ViewBag.Title modülü yakında!</div>
        <div>Bu modül sonraki fazda eklenecektir. Şimdilik Genel Bakış, Faturalar, Müşteri &amp; Tedarikçi ve Stok &amp; Hizmet modüllerini kullanabilirsiniz.</div>
        <a href="/" class="btn btn-isbasi mt-3"><i class="fas fa-chart-line me-1"></i> Genel Bakış'a Dön</a>
    </div>
</div>
