@model List<Payment>
@{
    ViewData["Title"] = "Tahsilat ve Ödemeler";
    string? direction = ViewBag.Direction as string;
    string? account = ViewBag.Account as string;
    decimal totalIn = Model.Where(p => p.Invoice!.IsCashIncoming).Sum(p => p.Amount);
    decimal totalOut = Model.Where(p => !p.Invoice!.IsCashIncoming).Sum(p => p.Amount);
}

<div class="page-header">
    <h1 class="page-title">Tahsilat ve Ödemeler</h1>
</div>

<div class="portlet">
    <form method="get" class="row g-2 mb-3">
        <div class="col-md-2">
            <select name="direction" class="form-select" onchange="this.form.submit()">
                <option value="" selected="@(string.IsNullOrEmpty(direction))">Hepsi</option>
                <option value="in" selected="@(direction == "in")">Tahsilatlar</option>
                <option value="out" selected="@(direction == "out")">Ödemeler</option>
            </select>
        </div>
        <div class="col-md-2">
            <select name="account" class="form-select" onchange="this.form.submit()">
                <option value="" selected="@(string.IsNullOrEmpty(account))">Tüm Hesaplar</option>
                <option value="safe" selected="@(account == "safe")">Kasa</option>
                <option value="bank" selected="@(account == "bank")">Banka</option>
            </select>
        </div>
        <div class="col-md-2"><input type="date" name="start" value="@(((DateTime?)ViewBag.Start)?.ToString("yyyy-MM-dd"))" class="form-control" /></div>
        <div class="col-md-2"><input type="date" name="end" value="@(((DateTime?)ViewBag.End)?.ToString("yyyy-MM-dd"))" class="form-control" /></div>
        <div class="col-md-3">
            <div class="input-group">
                <input name="q" value="@ViewBag.Query" class="form-control" placeholder="Firma ya da belge no ile ara..." />
                <button type="submit" class="btn btn-outline-secondary"><i class="fas fa-search"></i></button>
            </div>
        </div>
    </form>

    @if (Model.Count == 0)
    {
        <div class="empty-state">
            <i class="fas fa-money-bill"></i>
            <div class="title">Hareket bulunmuyor</div>
            <div>Seçilen kriterlere uyan tahsilat ya da ödeme yok.</div>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Tarih</th>
                        <th>Belge No</th>
                        <th>Firma</th>
                        <th>Tür</th>
                        <th>Hesap</th>
                        <th>Açıklama</th>
                        <th class="text-end">Tutar</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var payment in Model)
                    {
                        bool incoming = payment.Invoice!.IsCashIncoming;
                        <tr>
                            <td>@payment.Date.ToString("dd.MM.yyyy")</td>
                            <td><a href="/payment/add?invoiceId=@payment.InvoiceId" class="fw-medium text-decoration-none">@payment.Invoice.InvoiceNumber</a></td>
                            <td>@payment.Invoice.Firm?.Name</td>
                            <td>
                                <span class="status-badge @(incoming ? "status-paid" : "status-cancelled")">
                                    @(incoming ? "Tahsilat" : "Ödeme")
                                </span>
                            </td>
                            <td class="small">
                                <i class="fas @(payment.SafeId != null ? "fa-cash-register" : "fa-university") me-1 text-muted"></i>
                                @(payment.Safe?.Name ?? payment.BankAccount?.Name ?? "-")
                            </td>
                            <td class="text-muted small">@payment.Description</td>
                            <td class="text-end fw-medium @(incoming ? "text-success" : "text-danger")">
                                @(incoming ? "+" : "−")@payment.Amount.ToString("N2") ₺
                            </td>
                            <td class="text-end">
                                <a href="/payment/add?invoiceId=@payment.InvoiceId" class="btn btn-sm btn-outline-primary" title="Belgeye Git"><i class="fas fa-arrow-right"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="text-muted small">
            @Model.Count hareket —
            Tahsilat: <strong class="text-success">@totalIn.ToString("N2") ₺</strong>,
            Ödeme: <strong class="text-danger">@totalOut.ToString("N2") ₺</strong>,
            Net: <strong>@((totalIn - totalOut).ToString("N2")) ₺</strong>
        </div>
    }
</div>
