@model RecurringPlan
@{
    ViewData["Title"] = "Yeni Tekrarlama Planı";
    var invoice = (Invoice)ViewBag.Invoice;
}

<div class="page-header">
    <h1 class="page-title"><span class="breadcrumb-part"><a href="/recurring" class="text-decoration-none">Tekrarlayan Faturalar</a> &gt;</span> Yeni Plan</h1>
</div>

<div class="portlet" style="max-width:720px">
    <div class="border rounded p-3 mb-4" style="background:#fbfbfc">
        <div class="small text-muted mb-1">Kaynak Belge</div>
        <div class="d-flex justify-content-between flex-wrap gap-2">
            <div><span class="fw-medium">@invoice.InvoiceNumber</span> — @invoice.Firm?.Name</div>
            <div class="fw-medium">@invoice.GrandTotal.ToString("N2") @invoice.CurrencySymbol</div>
        </div>
        <div class="small text-muted mt-1">Her dönemde bu belgenin satırlarıyla yeni bir Açık fatura üretilir; tutarlar kaynak belgeden gelir.</div>
    </div>

    <form method="post" action="/recurring/create">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="SourceInvoiceId" />
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label" asp-for="Frequency"></label>
                <select asp-for="Frequency" class="form-select">
                    <option value="Weekly">Haftalık</option>
                    <option value="Monthly">Aylık</option>
                    <option value="Quarterly">3 Aylık</option>
                    <option value="Yearly">Yıllık</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label" asp-for="NextRunDate"></label>
                <input type="date" class="form-control" asp-for="NextRunDate" asp-format="{0:yyyy-MM-dd}" />
                <div class="form-text">Bugün ya da geçmiş bir tarih seçilirse fatura hemen üretilir.</div>
            </div>
            <div class="col-md-4">
                <label class="form-label" asp-for="EndDate"></label>
                <input type="date" class="form-control" asp-for="EndDate" asp-format="{0:yyyy-MM-dd}" />
                <div class="form-text">Boş bırakılırsa süresiz devam eder.</div>
            </div>
        </div>

        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-save"><i class="fas fa-save me-1"></i> Planı Oluştur</button>
            <a href="/recurring" class="btn btn-cancel"><i class="fas fa-times me-1"></i> Vazgeç</a>
        </div>
    </form>
</div>
