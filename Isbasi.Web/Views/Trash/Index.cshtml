@model List<Isbasi.Web.ViewModels.TrashRow>
@{
    ViewData["Title"] = "Çöp Kutusu";
    string? kind = ViewBag.Kind as string;
}

<div class="page-header">
    <h1 class="page-title">Çöp Kutusu</h1>
</div>

<div class="portlet">
    <p class="text-muted small mb-3">
        Silinen belgeler önce buraya taşınır; listelerden, raporlardan ve bakiyelerden düşer ama kaybolmaz.
        <strong>Geri Al</strong> belgeyi tüm bağlantılarıyla eski yerine döndürür. <strong>Kalıcı Sil</strong> geri alınamaz.
        Fatura çöpe taşındığında tahsilat/ödemeleri de birlikte taşınır ve geri almada birlikte döner.
    </p>

    <div class="mb-3">
        @{
            var filters = new (string? Value, string Label)[]
            {
                (null, "Tümü"),
                ("invoice", "Faturalar"),
                ("payment", "Tahsilat / Ödemeler"),
                ("cheque", "Çekler"),
                ("receipt", "Makbuzlar")
            };
        }
        @foreach (var f in filters)
        {
            <a href="/trash@(f.Value == null ? "" : $"?kind={f.Value}")"
               class="btn btn-sm @(kind == f.Value || (kind == "" && f.Value == null) ? "btn-primary" : "btn-outline-secondary") me-1">
                @f.Label
            </a>
        }
    </div>

    @if (Model.Count == 0)
    {
        <div class="empty-state">
            <i class="fas fa-trash"></i>
            <div class="title">Çöp kutusu boş</div>
            <div>Silinen belgeler burada listelenir ve tek tıkla geri alınabilir.</div>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Tür</th>
                        <th>Belge No</th>
                        <th>Firma</th>
                        <th class="text-end">Tutar (TL)</th>
                        <th>Silinme Tarihi</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model)
                    {
                        <tr>
                            <td>@row.KindLabel</td>
                            <td class="fw-medium">@row.Title</td>
                            <td>@row.Detail</td>
                            <td class="text-end fw-medium">@row.AmountTry.ToString("N2") ₺</td>
                            <td>@row.DeletedAt?.ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="text-end">
                                <form method="post" action="/trash/restore/@row.Kind/@row.Id" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-success" title="Geri Al">
                                        <i class="fas fa-undo"></i> Geri Al
                                    </button>
                                </form>
                                <form method="post" action="/trash/purge/@row.Kind/@row.Id" class="d-inline"
                                      onsubmit="return confirm('@row.Title kalıcı olarak silinecek ve GERİ ALINAMAYACAK. Emin misiniz?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Kalıcı Sil">
                                        <i class="fas fa-times"></i> Kalıcı Sil
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
